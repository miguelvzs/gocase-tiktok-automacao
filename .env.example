# Copie para .env e preencha. O .env não vai para o Git.
# Nenhuma destas chaves aparece no JSON do workflow n8n.

# --- Publicação (obrigatória) ---
# Zernio: transporte de publicação no TikTok. Chave em zernio.com → Dashboard.
# Formato: sk_ + 64 caracteres hexadecimais.
ZERNIO_API_KEY=
# ID da conta TikTok conectada. Obtido em GET /v1/accounts.
ZERNIO_TIKTOK_ACCOUNT_ID=

# --- Redação (obrigatória) ---
# Anthropic: conceito de arte, legenda e hashtags.
ANTHROPIC_API_KEY=

# --- Geração de mídia (opcional) ---
# Google AI Studio: uma chave cobre imagem (Imagen) e vídeo (Veo).
# Ausente ou sem cota: o pipeline cai para geração local por Pillow + FFmpeg
# e continua funcionando. A resposta informa qual caminho foi usado.
GOOGLE_API_KEY=

# --- Operação (opcional) ---
# true  = gera tudo e envia como rascunho, sem publicar. Use para testar.
# false = publica de verdade.
MODO_RASCUNHO=true
